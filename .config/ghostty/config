# Font
font-family = "FiraCode Nerd Font Mono"
font-size = 14

# Rendering
background-opacity = 1.0

# Behaviour
confirm-close-surface = false
copy-on-select = true
shell-integration-features = no-cursor

# Scrollback
scrollback-limit = 500000000

# Window
window-padding-x = 6
window-padding-y = 6

# Theme
theme = Nightfox
